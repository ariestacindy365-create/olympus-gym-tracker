// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  COACH
  MEMBER
}

enum PRType {
  MAX_WEIGHT
  MAX_1RM
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  pinHash      String
  role         Role
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  setEntries           SetEntry[]
  personalRecords      PersonalRecord[]
  dailyWorkoutsCreated DailyWorkout[]   @relation("CoachDailyWorkouts")
}

model Exercise {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  dailyWorkouts   DailyWorkout[]
  setEntries      SetEntry[]
  personalRecords PersonalRecord[]
}

// One broadcast per calendar day, visible to every member.
model DailyWorkout {
  id          String   @id @default(cuid())
  workoutDate DateTime
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  coachId     String
  coach       User     @relation("CoachDailyWorkouts", fields: [coachId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([workoutDate])
}

// One of a member's sets for one exercise on one day. Re-saving the same
// exercise+day+setNumber upserts (overwrites) rather than creating a new row.
model SetEntry {
  id           String   @id @default(cuid())
  memberId     String
  member       User     @relation(fields: [memberId], references: [id])
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id])
  workoutDate  DateTime
  setNumber    Int
  weight       Float
  reps         Int
  estimated1RM Float
  note         String?
  isPR         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([memberId, exerciseId, workoutDate, setNumber])
  @@index([workoutDate])
}

model PersonalRecord {
  id           String   @id @default(cuid())
  memberId     String
  member       User     @relation(fields: [memberId], references: [id])
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id])
  type         PRType
  weight       Float
  reps         Int
  estimated1RM Float
  setEntryId   String
  achievedAt   DateTime @default(now())

  @@unique([memberId, exerciseId, type])
}
