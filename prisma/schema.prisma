// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COACH
  MEMBER
}

enum PRType {
  MAX_WEIGHT
  MAX_1RM
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  pinHash      String
  role         Role
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  setEntries           SetEntry[]
  personalRecords      PersonalRecord[]
  dailyWorkoutsCreated DailyWorkout[]    @relation("CoachDailyWorkouts")
  programsAsCoach      TrainingProgram[] @relation("CoachPrograms")
}

model Exercise {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  dailyWorkouts   DailyWorkout[]
  setEntries      SetEntry[]
  personalRecords PersonalRecord[]
}

// One broadcast per calendar day, visible to every member.
model DailyWorkout {
  id          String   @id @default(cuid())
  workoutDate DateTime
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  coachId     String
  coach       User     @relation("CoachDailyWorkouts", fields: [coachId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([workoutDate])
}

// One of a member's sets for one exercise on one day. Re-saving the same
// exercise+day+setNumber upserts (overwrites) rather than creating a new row.
model SetEntry {
  id           String   @id @default(cuid())
  memberId     String
  member       User     @relation(fields: [memberId], references: [id])
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id])
  workoutDate  DateTime
  setNumber    Int
  weight       Float
  reps         Int
  estimated1RM Float
  note         String?
  isPR         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([memberId, exerciseId, workoutDate, setNumber])
  @@index([workoutDate])
}

model PersonalRecord {
  id           String   @id @default(cuid())
  memberId     String
  member       User     @relation(fields: [memberId], references: [id])
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id])
  type         PRType
  weight       Float
  reps         Int
  estimated1RM Float
  setEntryId   String
  achievedAt   DateTime @default(now())

  @@unique([memberId, exerciseId, type])
}

// Master exercise dictionary for building training programs (coach-only).
// Deliberately separate from Exercise (which members pick from when logging
// sets) so the much larger movement library doesn't bloat that dropdown.
model Movement {
  id              String   @id @default(cuid())
  code            String?
  name            String   @unique
  primaryMuscle   String?
  secondaryMuscle String?
  category        String?
  equipment       String?
  repRangeHint    String?
  setRangeHint    String?
  createdAt       DateTime @default(now())

  slots ProgramSlot[]
}

// A single shared weekly bootcamp-class program, visible to every coach —
// not tied to an individual member.
model TrainingProgram {
  id         String   @id @default(cuid())
  weekNumber Int      @unique
  coachId    String
  coach      User     @relation("CoachPrograms", fields: [coachId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  days ProgramDay[]
}

model ProgramDay {
  id         String          @id @default(cuid())
  programId  String
  program    TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  dayLabel   String
  focusLabel String?
  order      Int

  slots ProgramSlot[]

  @@unique([programId, order])
}

model ProgramSlot {
  id           String     @id @default(cuid())
  dayId        String
  day          ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  slotLabel    String?
  movementId   String
  movement     Movement   @relation(fields: [movementId], references: [id])
  sets         Int?
  repTarget    String?
  targetWeight Float?
  note         String?
  order        Int

  @@index([dayId])
}
